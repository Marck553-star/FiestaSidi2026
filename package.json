{
  "name": "fiestas-sidi-2026-neon",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "description": "Sistema completo de inscripciones para Fiestas SIDI 2026: React, Express, PostgreSQL/Neon, Replit y acceso local mediante Apache de XAMPP.",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "local:xampp": "npm run build && npm run start",
    "check": "tsc --noEmit",
    "check:sports": "tsx scripts/check-sports.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
